#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols
# Split debug info directory (--split-debug-info=./symbols)
/symbols/

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release
android/key.properties
android/*.keystore
android/app/*.keystore
android/app/*.jks
**/*.keystore
**/*.jks
**/*.p12

# Windows reserved filenames (cannot be tracked by git on Windows)
CON
NUL
nul

# Windows PowerShell shell-mishap files accidentally created at repo root.
# These were observed after running ps commands with bad redirection.
/$dir
/Get-ChildItem
/cd
/dir
/jar

# Garbled path directories from Windows path separator bugs
C:devgeo_quiz*/

# Cache directories
.cache/

# Asset junk files (tool-generated cache/log files that must never enter the bundle)
**/.....cache*
**/*cleanup_before*.txt
**/*cleanup_after*.txt
**/report*.txt
**/*.tmp
**/*.bak
**/*.cache
data/*.backup
data/*backup*
data/backups/
# Asset backup snapshots (pre-optimize) — never commit, always large.
assets/*__backup/
assets/**/*__backup/
assets/brand/__backup_pre_premium/
# Premium icon master source (1MB) — kept locally, not committed.
assets/premium_*.png
data/mode_separation_report_*.txt
data/review_log.csv

# Reports (generated)
QA_REPORT.md
FIX_REPORT.md

# analysis leftovers
_legacy/
analyze_*.py
*analysis_report.json
mode_separation.py
README_CAPITAL_PHOTOS_ANALYSIS.md
*_analysis.py
