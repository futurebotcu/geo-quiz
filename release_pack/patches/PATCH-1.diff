+                   );
+                 }
+               },
+             ),
            IconButton(

--- VERIFICATION:
--- kDebugMode is a compile-time constant in Flutter. In release/profile builds,
--- the entire block is tree-shaken (dead code eliminated). Zero runtime cost.
--- Run: flutter build apk --release  → button will NOT appear.
